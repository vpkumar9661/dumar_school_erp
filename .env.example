# VVM School ERP v2.0 — Environment Variables (Supabase/PostgreSQL)
# Copy this to .env and fill in your values
# On Render: Add these in Dashboard → Environment → Environment Variables

# ── Supabase PostgreSQL Connection String ────────────────────
# Get from: Supabase Dashboard → Settings → Database → Connection string → URI
# Use "Session mode" (port 5432) for this app
# IMPORTANT: URL-encode special chars in password (@ → %40, # → %23, etc.)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# ── Supabase Cloud Storage ──────────────────────────────────
# Get from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_public_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Flask Secret Key ─────────────────────────────────────────
# Generate a strong random key for production!
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_this_to_a_random_string_in_production

# ── School Info (optional overrides) ─────────────────────────
SCHOOL_NAME=Vivekanand Vidya Mandir Dharampur
SCHOOL_ADDRESS=Dharampur, Tatijhariya Hazaribagh, Jharkhand
SCHOOL_PHONE=7070373801
SCHOOL_EMAIL=demoa4447@gmail.com

# ── SMTP Configuration (Email Notifications) ──────────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# ── AI Keys (optional) ──────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key